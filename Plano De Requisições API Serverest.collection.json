  "item": [
    {
      "name": "Listar Usuários Cadastrados",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Código de Status é 200\",function (){\r",
              "    pm.response.to.have.status(200)\r",
              "})\r",
              "pm.test(\"Válida o tempo de consulta menor 1000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});\r",
              "var schema = {\r",
              "   \r",
              "  \"quantidade\": 'integer',\r",
              "  \"usuarios\": [\r",
              "    {\r",
              "      \"nome\": \"string\",\r",
              "      \"email\": \"string\",\r",
              "      \"password\": \"string\",\r",
              "      \"administrador\": \"boolean\",\r",
              "      \"_id\": \"string\"\r",
              "    }\r",
              "  ]\r",
              "\r",
              "};\r",
              "\r",
              "var jsonData = pm.response.json()\r",
              "\r",
              "pm.test('Validar a estrutura do body', function () {\r",
              "    pm.expect(tv4.validate(jsonData , schema)).to.be.true\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
