        {
          "name": "GET / Usuários",
          "item": [
            {
              "name": "Lista todos os usuários",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "//Set Variáveis do ENV\r",
                      "\r",
                      "pm.collectionVariables.set('_idUsuarioCadastrado', pm.response.json().usuarios[0]._id)\r",
                      "\r",
                      "//Execução dos testes\r",
                      "\r",
                      "pm.test(\"Retorna o Status de sucesso (200)\", () => pm.response.to.have.status(200));\r",
                      "\r",
                      "pm.test(\"Retorno no tipo application/json\", () => {\r",
                      "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Resposta possui quantdade \", () => {\r",
                      "    var body = pm.response.json();\r",
                      "    pm.expect(body).to.have.property(\"quantidade\");\r",
                      "    pm.expect(body).to.have.property(\"usuarios\").that.is.an(\"array\");\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Campos obrigatórios e tipos corretos\", () => {\r",
                      "    var { usuarios } = pm.response.json();\r",
                      "    usuarios.forEach(u => {\r",
                      "        pm.expect(u).to.have.keys([\"nome\", \"email\", \"password\", \"administrador\", \"_id\"]);\r",
                      "        pm.expect(u.nome).to.be.a(\"string\");\r",
                      "        pm.expect(u.email).to.be.a(\"string\").and.match(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/);\r",
                      "        pm.expect(u.administrador).to.be.oneOf([\"true\", \"false\"]);\r",
                      "    });\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Responde em menos de 2000ms\", () => {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Quantidade bate com tamanho do array\", () => {\r",
                      "  var body = pm.response.json();\r",
                      "  pm.expect(body.quantidade).to.equal(body.usuarios.length);\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
