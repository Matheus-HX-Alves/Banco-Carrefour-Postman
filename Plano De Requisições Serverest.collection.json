          "name": "POST / Usuários",
          "item": [
            {
              "name": "Cadastrar Usuário",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "//Set Variáveis da collectionVariables \r",
                      "\r",
                      "pm.collectionVariables.set('_idUsuarioCadastrado', pm.response.json()._id)\r",
                      "\r",
                      "//Execução dos testes\r",
                      "\r",
                      "pm.test(\"Retorna o Status de sucesso (201)\", () => pm.response.to.have.status(201));\r",
                      "\r",
                      "pm.test(\"Retorno no tipo application/json\", () => {\r",
                      "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Resposta possui 'message' e '_id' \", () => {\r",
                      "    var body = pm.response.json();\r",
                      "    pm.expect(body).to.have.property(\"message\");\r",
                      "    pm.expect(body).to.have.property(\"_id\");\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Resposta message é 'Cadastro realizado com sucesso' \", () => {\r",
                      "  var body = pm.response.json();\r",
                      "  pm.expect(body.message).to.equal(\"Cadastro realizado com sucesso\"); \r",
                      "});\r",
                      "\r",
                      "pm.test(\"Responde em menos de 2000ms\", () => {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
                      "});\r",
                      " "
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      "const userDate = Date.now();\r",
                      "const userNumbRand = Math.random().toString(36).substring(2, 6);\r",
                      "const passRand = Math.random().toString(36).substring(2, 10);\r",
                      "\r",
                      "pm.collectionVariables.set(\"nomeUsuarioCadastrado\",  `Usuario Teste ${userDate}`);\r",
                      "pm.collectionVariables.set(\"emailUsuarioCadastrado\", `teste_${userDate}_${userNumbRand}@qa.com`);\r",
                      "pm.collectionVariables.set(\"senhaUsuarioCadastrado\", `${passRand}`); "
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
